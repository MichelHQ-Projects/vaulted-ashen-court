; Engine configuration file.
[configuration]
config_version=5

[application]
config/name="VAULTED: The Ashen Court"
config/features=PackedStringArray("4.2")
config/icon="res://assets/ui/icon.png"

[display]
window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[autoload]
EventBus="*res://scripts/autoload/event_bus.gd"
GameData="res://scripts/autoload/game_data.gd"
RunManager="res://scripts/autoload/run_manager.gd"
CardManager="res://scripts/autoload/card_manager.gd"

[rendering]
renderer/rendering_method="gl_compatibility"
